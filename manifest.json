{
  "manifest_version":  3,
  "name": "ウェブタイムトラッカー",
  "version": "1.0",
  "description": "ウェブサイトごとの閲覧時間を計測します（離席時間などを除外）。",
  "permissions": [
    "tabs",
    "storage",
    "idle" 
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}